/* 创建订单 */
.order-create {
  min-height: 100vh;
  background: #f6f6f6;
  padding-bottom: 140rpx;
}

.section {
  margin: 24rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 24rpx;
}

/* 物品列表 */
.item-list {
  border-top: 1rpx solid #f0f0f0;
}

.item-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.item-row:last-child {
  border-bottom: none;
}

.item-info {
  flex: 1;
}

.item-name {
  font-size: 30rpx;
  color: #333;
}

.item-price {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #07c160;
}

.item-input input {
  width: 180rpx;
  text-align: right;
  font-size: 28rpx;
  color: #333;
}

.min-tip {
  margin-top: 16rpx;
  font-size: 24rpx;
  color: #999;
  text-align: center;
}

/* 照片网格 */
.photo-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.photo-item {
  width: calc((100% - 40rpx) / 3);
  aspect-ratio: 1;
  position: relative;
}

.photo-item image {
  width: 100%;
  height: 100%;
  border-radius: 12rpx;
}

.photo-delete {
  position: absolute;
  top: -12rpx;
  right: -12rpx;
  width: 40rpx;
  height: 40rpx;
  line-height: 36rpx;
  text-align: center;
  background: #f00;
  color: #fff;
  border-radius: 50%;
  font-size: 28rpx;
}

.photo-add {
  width: calc((100% - 40rpx) / 3);
  aspect-ratio: 1;
  border: 2rpx dashed #ddd;
  border-radius: 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.add-icon {
  font-size: 48rpx;
  color: #999;
}

.add-text {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #999;
}

/* 地址卡片 */
.address-card {
  padding: 24rpx;
  background: #fafafa;
  border-radius: 12rpx;
}

.address-info {
  display: flex;
  flex-direction: column;
}

.address-contact {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
}

.address-detail {
  margin-top: 8rpx;
  font-size: 26rpx;
  color: #666;
  line-height: 1.4;
}

.address-empty {
  display: flex;
  align-items: center;
  justify-content: space-between;
  color: #999;
  font-size: 28rpx;
}

/* 表单项目 */
.form-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.form-item:last-child {
  border-bottom: none;
}

.label {
  font-size: 28rpx;
  color: #666;
}

.picker-value {
  display: flex;
  align-items: center;
  font-size: 28rpx;
  color: #333;
}

.arrow {
  margin-left: 16rpx;
  color: #ccc;
  font-size: 32rpx;
}

/* 备注输入 */
.remark-input {
  width: 100%;
  height: 160rpx;
  padding: 20rpx;
  background: #fafafa;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
}

/* 底部提交 */
.footer {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: #fff;
  padding: 20rpx 32rpx;
  box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.submit-btn {
  width: 100%;
  background: #07c160;
  color: #fff;
  font-size: 32rpx;
  font-weight: bold;
  padding: 24rpx;
  border-radius: 40rpx;
  margin: 0;
}

.submit-btn::after {
  border: none;
}