/* 品类列表 */
.category {
  min-height: 100vh;
  background: #f6f6f6;
  padding-bottom: 140rpx;
}

.state-tip {
  text-align: center;
  color: #999;
  font-size: 28rpx;
  padding-top: 200rpx;
}

.cat-list {
  padding: 24rpx;
}
.cat-card {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 20rpx;
  border: 2rpx solid transparent;
}
.cat-card.selected {
  border-color: #07c160;
  background: #f0fbf5;
}
.cat-icon {
  font-size: 48rpx;
  margin-right: 24rpx;
}
.cat-info {
  flex: 1;
}
.cat-name {
  font-size: 32rpx;
  color: #333;
  font-weight: 500;
}
.cat-price {
  margin-top: 8rpx;
  font-size: 26rpx;
  color: #999;
}
.cat-check {
  width: 44rpx;
  height: 44rpx;
  line-height: 44rpx;
  text-align: center;
  border-radius: 50%;
  background: #07c160;
  color: #fff;
  font-size: 28rpx;
}
.cat-card:not(.selected) .cat-check {
  background: #eee;
}

/* 底部 */
.footer {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: #fff;
  padding: 20rpx 32rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.05);
}
.footer-tip {
  font-size: 28rpx;
  color: #666;
}
.next-btn {
  background: #07c160;
  color: #fff;
  font-size: 30rpx;
  padding: 0 60rpx;
  border-radius: 40rpx;
  margin: 0;
}
