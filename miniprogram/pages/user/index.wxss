/* 个人中心 */
.user {
  min-height: 100vh;
  background: #f6f6f6;
}

/* 头像昵称 */
.profile {
  background: linear-gradient(135deg, #07c160, #10ad7a);
  padding: 60rpx 40rpx;
  display: flex;
  align-items: center;
}

.profile-info {
  display: flex;
  align-items: center;
  width: 100%;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: #fff;
}

.profile-text {
  margin-left: 28rpx;
  flex: 1;
}

.nickname {
  color: #fff;
  font-size: 34rpx;
  font-weight: bold;
}

.logout-btn {
  margin-top: 8rpx;
  color: rgba(255, 255, 255, 0.8);
  font-size: 24rpx;
}

.phone {
  margin-top: 6rpx;
  color: rgba(255, 255, 255, 0.9);
  font-size: 26rpx;
}

/* 登录区域 */
.login-area {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* 登录面板表单 */
.login-form {
  width: 100%;
  background: #fff;
  border-radius: 16rpx;
  padding: 40rpx 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* 头像选择按钮 */
.avatar-btn {
  background: transparent;
  padding: 0;
  line-height: normal;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.avatar-btn::after {
  border: none;
}

.avatar-btn .avatar {
  width: 140rpx;
  height: 140rpx;
  border: 2rpx solid #eee;
}

.avatar-tip {
  margin-top: 12rpx;
  color: #999;
  font-size: 24rpx;
}

/* 昵称行 / 手机号行 */
.nickname-row,
.phone-row {
  width: 100%;
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.nickname-label,
.phone-label {
  width: 120rpx;
  font-size: 30rpx;
  color: #333;
}

.nickname-input {
  flex: 1;
  font-size: 30rpx;
  color: #333;
}

.phone-value {
  flex: 1;
  font-size: 30rpx;
  color: #333;
}

.phone-btn {
  flex: 1;
  margin: 0;
  background: #f6f6f6;
  color: #07c160;
  font-size: 28rpx;
  border-radius: 12rpx;
}

.phone-btn::after {
  border: none;
}

.login-btn {
  margin-top: 40rpx;
  background: #07c160;
  color: #fff;
  font-size: 32rpx;
  font-weight: bold;
  padding: 20rpx 80rpx;
  border-radius: 40rpx;
}

.login-btn::after {
  border: none;
}

.login-desc {
  margin-top: 16rpx;
  color: #999;
  font-size: 24rpx;
}

/* 菜单 */
.menu {
  margin: 24rpx;
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
}

.menu-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon {
  font-size: 36rpx;
  margin-right: 20rpx;
}

.menu-label {
  flex: 1;
  font-size: 30rpx;
  color: #333;
}

.arrow {
  color: #ccc;
  font-size: 36rpx;
}