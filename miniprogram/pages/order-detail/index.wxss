/* 订单详情 */
.order-detail {
  min-height: 100vh;
  background: #f6f6f6;
  padding-bottom: 140rpx;
}
.state-tip {
  text-align: center;
  color: #999;
  font-size: 28rpx;
  padding-top: 200rpx;
}

/* 状态头 */
.status-head {
  background: linear-gradient(135deg, #07c160, #10ad7a);
  color: #fff;
  padding: 48rpx 40rpx;
}
.status-text {
  font-size: 40rpx;
  font-weight: bold;
}
.order-no {
  margin-top: 16rpx;
  font-size: 26rpx;
  opacity: 0.9;
}

/* 进度条 */
.progress {
  display: flex;
  background: #fff;
  padding: 40rpx 20rpx;
  margin: 20rpx 24rpx;
  border-radius: 16rpx;
}
.step {
  flex: 1;
  text-align: center;
  position: relative;
}
.step .dot {
  width: 48rpx;
  height: 48rpx;
  line-height: 48rpx;
  border-radius: 50%;
  background: #e5e5e5;
  color: #fff;
  font-size: 26rpx;
  margin: 0 auto;
}
.step.done .dot,
.step.current .dot {
  background: #07c160;
}
.step-label {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #999;
}
.step.done .step-label,
.step.current .step-label {
  color: #07c160;
}
/* 连接线 */
.step::before {
  content: "";
  position: absolute;
  top: 24rpx;
  left: -50%;
  width: 100%;
  height: 4rpx;
  background: #e5e5e5;
  z-index: 0;
}
.step:first-child::before {
  display: none;
}
.step.done::before {
  background: #07c160;
}
.step .dot {
  position: relative;
  z-index: 1;
}

/* 通用 block */
.block {
  background: #fff;
  margin: 20rpx 24rpx;
  border-radius: 16rpx;
  padding: 28rpx 32rpx;
}
.block-title {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 20rpx;
}
.reject .reject-text {
  font-size: 30rpx;
  color: #e64340;
}

.item-row {
  display: flex;
  justify-content: space-between;
  padding: 16rpx 0;
}
.item-name {
  font-size: 30rpx;
  color: #333;
}
.item-qty {
  font-size: 30rpx;
  color: #666;
}

.photo-grid {
  display: flex;
  flex-wrap: wrap;
}
.photo-img {
  width: 200rpx;
  height: 200rpx;
  margin: 8rpx;
  border-radius: 12rpx;
}

.addr-line {
  font-size: 32rpx;
  color: #333;
}
.addr-detail {
  margin-top: 10rpx;
  font-size: 28rpx;
  color: #666;
}

.info-row {
  display: flex;
  justify-content: space-between;
  padding: 14rpx 0;
}
.info-row .k {
  font-size: 28rpx;
  color: #999;
}
.info-row .v {
  font-size: 28rpx;
  color: #333;
}
.info-row .v.price {
  color: #e64340;
  font-weight: bold;
}

/* 底部取消 */
.footer {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 20rpx 32rpx;
  background: #fff;
  box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.05);
}
.cancel-btn {
  background: #fff;
  color: #e64340;
  font-size: 32rpx;
  border: 1rpx solid #e64340;
  border-radius: 44rpx;
}
